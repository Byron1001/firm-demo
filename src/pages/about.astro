---
import { asset } from '../lib/assets'
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header'
import Stats from '../sections/Stats.astro'
import DataTable from '../sections/DataTable.astro'
import Team from '../sections/Team.astro'
import DualCta from '../sections/DualCta.astro'
import Contact from '../sections/Contact.astro'
import Footer from '../sections/Footer.astro'
import FloatingButtons from '../sections/FloatingButtons.astro'
---

<Layout title="About — Double Brain Creative & Event SDN BHD">
  <Header client:load />

  <section class="pt-32 pb-20 bg-bg-dark text-white overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-6">Est. 2023</p>
      <h1 class="font-heading text-[clamp(2.5rem,5vw,4.5rem)] font-bold leading-[1.02] tracking-[-0.04em] max-w-[700px] mb-6">
        The creative event agency behind unforgettable brand moments
      </h1>
      <p class="text-white/50 max-w-[600px] text-lg leading-relaxed mb-12">
        Beyond flawless execution, it's our mindset that makes the difference. We combine human-first thinking, creative precision, and an obsession with detail that earns the spotlight.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/#contact" class="inline-flex items-center gap-2.5 bg-accent text-primary font-semibold px-6 py-3.5 rounded-full hover:bg-accent-dark transition-[background-color,transform] hover:-translate-y-0.5 text-sm">
          Start Your Event
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href="/careers" class="inline-flex items-center gap-2.5 bg-white/10 text-white font-semibold px-6 py-3.5 rounded-full border border-white/20 hover:bg-white/20 transition-[background-color,transform] hover:-translate-y-0.5 text-sm">
          Join Our Team
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-[100px] bg-bg-alt border-b border-white/10">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-10 h-px bg-accent bar-reveal" />
            <span class="text-xs font-semibold tracking-[0.2em] uppercase text-accent">What We're Made Of</span>
          </div>
          <h2 class="font-heading text-[clamp(1.8rem,3.5vw,2.5rem)] font-bold leading-[1.08] tracking-[-0.03em] mb-6">Passion meets precision</h2>
          <p class="text-text-light leading-relaxed mb-6">
            Double Brain Creative & Event SDN BHD (202301030587(1524510-W)) has grown from a small creative studio into one of Malaysia's most trusted event management partners. We've produced events for Fortune 500 companies, government agencies, and some of the region's most recognised brands.
          </p>
          <p class="text-text-light leading-relaxed mb-6">
            Our team of creative professionals brings together expertise in corporate events, exhibitions, wedding planning, and brand design. We believe that every event is an opportunity to tell a story — and we treat each one with the same obsession for detail.
          </p>
          <p class="text-text-light leading-relaxed">
            We are a group of passionate event professionals who input creative and technical proficiency into bringing events to life. Whether corporate conferences, dream weddings, or immersive brand activations — we craft experiences that audiences feel, not just attend.
          </p>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden">
            <img src={asset('/images/sections/about-team.jpg')} alt="Double Brain Creative team at work" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Stats />
  <DataTable />
  <Team />

  <section class="py-[100px] bg-bg-alt border-t border-white/10">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16 text-center">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-4">Join Us</p>
      <h2 class="font-heading text-[clamp(1.8rem,3.5vw,2.5rem)] font-bold leading-[1.08] tracking-[-0.03em] mb-4">We're always looking for sharp minds</h2>
      <p class="text-text-light max-w-[500px] mx-auto mb-8">Explore our open roles and see where you fit in.</p>
      <a href="/careers" class="inline-flex items-center gap-2.5 bg-primary text-white font-semibold px-8 py-4 rounded-full hover:bg-accent hover:text-primary transition-[background-color,color,transform] hover:-translate-y-0.5">
        Apply here
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  <DualCta />
  <Contact />
  <Footer />
  <FloatingButtons />
</Layout>
