---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header'
import Contact from '../sections/Contact.astro'
import Footer from '../sections/Footer.astro'
import FloatingButtons from '../sections/FloatingButtons.astro'

const articles = [
  { date: '12 Jun 2026', category: 'Event Strategy', title: 'Choosing the Right Event Venue: A Complete Guide for Malaysian Brands', desc: 'From KLCC to Sentul Depot — how to pick a venue that amplifies your brand narrative and delights your guests without breaking the budget.', slug: 'choosing-event-venue-guide' },
  { date: '28 May 2026', category: 'Trends', title: '2026 Event Trends: Immersive Tech, Sustainable Production & Hyper-Personalisation', desc: 'The biggest shifts shaping events this year — from AI-powered guest journeys to zero-waste stage builds that look anything but minimal.', slug: '2026-event-trends-immersive-tech' },
  { date: '15 Apr 2026', category: 'Behind the Scenes', title: 'How We Produced a 3-City Launch in 72 Hours', desc: 'Behind-the-scenes look at a high-stakes product launch across Penang, KL, and Johor — logistics, team coordination, and how we pulled it off.', slug: 'three-city-launch-72-hours' },
]
---

<Layout title="Insights — Double Brain Creative & Event">
  <Header client:load />

  <section class="pt-32 pb-20 bg-bg-dark text-white">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-4">Inside Double Brain</p>
      <h1 class="font-heading text-[clamp(2.5rem,5vw,4rem)] font-bold leading-[1.05] tracking-[-0.03em] max-w-[600px] mb-4">Insights & Stories</h1>
      <p class="text-white/50 max-w-[500px]">Get insider tips, bold ideas, and future-forward trends from the frontlines of unforgettable events.</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {articles.map((a) => (
          <article class="group border border-gray-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
            <div class="p-8 flex flex-col h-full">
              <div class="flex items-center gap-3 text-xs text-text-muted mb-4">
                <time>{a.date}</time>
                <span class="w-px h-3 bg-gray-300" />
                <span class="text-accent font-medium">{a.category}</span>
              </div>
              <h2 class="font-heading text-lg font-bold text-primary mb-3 group-hover:text-accent transition-colors">
                {a.title}
              </h2>
              <p class="text-text-light text-sm leading-relaxed flex-1 mb-6">{a.desc}</p>
              <a href={`/insights/${a.slug}`} class="inline-flex items-center gap-2 text-sm font-semibold text-accent group-hover:gap-3 transition-all">
                Read more
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Contact />
  <Footer />
  <FloatingButtons />
</Layout>
