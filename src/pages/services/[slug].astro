---

<Layout title={`${Astro.props.title} — Double Brain Creative & Event`}>
  <Header client:load />

  <section class="relative h-[60vh] min-h-[500px] flex items-end pb-16 overflow-hidden bg-bg-dark">
    <img src={Astro.props.hero} alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f0f1a] via-[#0f0f1a]/50 to-transparent" />
    <div class="relative z-10 max-w-[1440px] mx-auto px-6 lg:px-16 w-full">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-4">{Astro.props.title}</p>
      <h1 class="font-heading text-[clamp(2rem,5vw,4rem)] font-bold leading-[1.05] tracking-[-0.03em] text-white max-w-[700px]">
        {Astro.props.tagline}
      </h1>
    </div>
  </section>

  <section class="py-[100px] bg-white">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="font-heading text-2xl font-bold text-primary mb-6">{Astro.props.sections[0].heading}</h2>
          <p class="text-text-light leading-relaxed text-[1.05rem]">{Astro.props.sections[0].body}</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold tracking-[0.15em] uppercase text-accent mb-6">What We Deliver</h3>
          {Astro.props.categories ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {Astro.props.categories.map((cat: { heading: string; icon: string; items: string[] }) => (
                <div class="bg-bg-alt rounded-xl p-5 border border-gray-100">
                  <div class="flex items-center gap-2.5 mb-3">
                    <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
                    </svg>
                    <h4 class="text-xs font-semibold tracking-[0.12em] uppercase text-accent">{cat.heading}</h4>
                  </div>
                  <ul class="space-y-1.5">
                    {cat.items.map((item: string) => (
                      <li class="flex items-start gap-2">
                        <span class="w-1 h-1 rounded-full bg-primary/30 mt-2 shrink-0" />
                        <span class="text-text-light text-[0.85rem] leading-relaxed">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          ) : (
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {Astro.props.subs.map((sub: string) => (
                <li class="flex items-center gap-3 py-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0" />
                  <span class="text-text-light text-sm">{sub}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>
  </section>

  <Cta />
  <Contact />
  <Footer />
  <FloatingButtons />
</Layout>
