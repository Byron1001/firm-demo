---
import { asset } from '../../../lib/assets'
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/Header'
import Cta from '../../../sections/Cta.astro'
import Contact from '../../../sections/Contact.astro'
import Footer from '../../../sections/Footer.astro'
import FloatingButtons from '../../../sections/FloatingButtons.astro'
import { useTranslations } from '../../../i18n'

const t = useTranslations('ms')

const slugMap: Record<string, string> = {
  'grab-brand-launch': 'grab-brand-launch-2025',
}

export function getStaticPaths() {
  return [
    { params: { slug: 'petronas-leadership-summit' }, props: { hero: '/images/sections/portfolio-03.jpg' } },
    { params: { slug: 'airasia-annual-gala' }, props: { hero: '/images/sections/portfolio-02.jpg' } },
    { params: { slug: 'grab-brand-launch' }, props: { hero: '/images/sections/portfolio-05.jpg' } },
    { params: { slug: 'shopeefest-malaysia' }, props: { hero: '/images/sections/portfolio-04.jpg' } },
    { params: { slug: 'celcomdigi-conference' }, props: { hero: '/images/sections/portfolio-06.jpg' } },
    { params: { slug: 'sunway-wedding-fair' }, props: { hero: '/images/sections/portfolio-01.jpg' } },
  ]
}

const slug = Astro.params.slug!
const { hero } = Astro.props
const key = slugMap[slug] || slug
const p = t.caseStudy.slug[key]
const sl = t.caseStudy.statLabels
const lb = t.caseStudy.labels
---

<Layout title={`${p.title} — Double Brain Creative & Event SDN BHD`} locale="ms">
  <Header client:load locale="ms" />

  <section class="relative h-[60vh] min-h-[500px] flex items-end pb-16 overflow-hidden bg-bg-dark">
    <img src={asset(hero)} alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f0f1a] via-[#0f0f1a]/50 to-transparent" />
    <div class="relative z-10 max-w-[1440px] mx-auto px-6 lg:px-16 w-full">
      <div class="flex items-center gap-3 text-accent text-xs font-semibold tracking-[0.15em] uppercase mb-4">
        <span>{p.category}</span>
        <span class="w-px h-3 bg-accent/50" />
        <span>{p.location}</span>
      </div>
      <h1 class="font-heading text-[clamp(2rem,5vw,4rem)] font-bold leading-[1.05] tracking-[-0.03em] text-white max-w-[700px]">
        {p.title}
      </h1>
    </div>
  </section>

  <section class="py-[80px] bg-bg-alt border-b border-white/10">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="flex flex-wrap gap-12 mb-16">
        <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.participants}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.participants}</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.duration}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.duration}</p>
        </div>
        {p.stats.speakers && <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.speakers}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.speakers}</p>
        </div>}
        {p.stats.awards && <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.awards}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.awards}</p>
        </div>}
        {p.stats.brands && <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.brands}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.brands}</p>
        </div>}
        {p.stats.demos && <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.demos}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.demos}</p>
        </div>}
        {p.stats.workshops && <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.workshops}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.workshops}</p>
        </div>}
        {p.stats.vendors && <div class="text-center">
          <p class="font-heading text-3xl font-bold text-primary">{p.stats.vendors}</p>
          <p class="text-xs text-text-muted tracking-wider uppercase mt-1">{sl.vendors}</p>
        </div>}
      </div>

      <div class="max-w-[800px]">
        <p class="text-lg leading-relaxed text-primary mb-10">{p.overview}</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h2 class="font-heading text-sm font-semibold tracking-[0.15em] uppercase text-accent mb-4">{lb.challenge}</h2>
            <p class="text-text-light leading-relaxed">{p.challenge}</p>
          </div>
          <div>
            <h2 class="font-heading text-sm font-semibold tracking-[0.15em] uppercase text-accent mb-4">{lb.solution}</h2>
            <p class="text-text-light leading-relaxed">{p.solution}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Cta locale="ms" />
  <Contact locale="ms" />
  <Footer locale="ms" />
  <FloatingButtons />
</Layout>
