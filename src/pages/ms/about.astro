---
import { useTranslations } from '../../i18n'
const t = useTranslations('ms')
import { asset } from '../../lib/assets'
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header'
import Stats from '../../sections/Stats.astro'
import DataTable from '../../sections/DataTable.astro'
import Team from '../../sections/Team.astro'
import DualCta from '../../sections/DualCta.astro'
import Contact from '../../sections/Contact.astro'
import Footer from '../../sections/Footer.astro'
import FloatingButtons from '../../sections/FloatingButtons.astro'
---

<Layout title={t.aboutPage.title} locale="ms">
  <Header client:load locale="ms" />

  <section class="pt-32 pb-20 bg-bg-dark text-white overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-6">{t.aboutPage.hero.est}</p>
      <h1 class="font-heading text-[clamp(2.5rem,5vw,4.5rem)] font-bold leading-[1.02] tracking-[-0.04em] max-w-[700px] mb-6">
        {t.aboutPage.hero.heading}
      </h1>
      <p class="text-white/50 max-w-[600px] text-lg leading-relaxed mb-12">
        {t.aboutPage.hero.subtitle}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href={`${import.meta.env.BASE_URL}#contact`} class="inline-flex items-center gap-2.5 bg-accent text-primary font-semibold px-6 py-3.5 rounded-full hover:bg-accent-dark transition-[background-color,transform] hover:-translate-y-0.5 text-sm">
          {t.aboutPage.hero.cta_primary}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href={`${import.meta.env.BASE_URL}careers`} class="inline-flex items-center gap-2.5 bg-white/10 text-white font-semibold px-6 py-3.5 rounded-full border border-white/20 hover:bg-white/20 transition-[background-color,transform] hover:-translate-y-0.5 text-sm">
          {t.aboutPage.hero.cta_secondary}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-[100px] bg-bg-alt border-b border-white/10">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-10 h-px bg-accent bar-reveal" />
            <span class="text-xs font-semibold tracking-[0.2em] uppercase text-accent">{t.aboutPage.story.sectionLabel}</span>
          </div>
          <h2 class="font-heading text-[clamp(1.8rem,3.5vw,2.5rem)] font-bold leading-[1.08] tracking-[-0.03em] mb-6">{t.aboutPage.story.heading}</h2>
          <p class="text-text-light leading-relaxed mb-6">
            {t.aboutPage.story.paragraph1}
          </p>
          <p class="text-text-light leading-relaxed mb-6">
            {t.aboutPage.story.paragraph2}
          </p>
          <p class="text-text-light leading-relaxed">
            {t.aboutPage.story.paragraph3}
          </p>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden">
            <img src={asset('/images/sections/about-team.jpg')} alt={t.aboutPage.imageAlt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Stats locale="ms" />
  <DataTable locale="ms" />
  <Team locale="ms" />

  <section class="py-[100px] bg-bg-alt border-t border-white/10">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16 text-center">
      <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-4">{t.aboutPage.joinUs.sectionLabel}</p>
      <h2 class="font-heading text-[clamp(1.8rem,3.5vw,2.5rem)] font-bold leading-[1.08] tracking-[-0.03em] mb-4">{t.aboutPage.joinUs.heading}</h2>
      <p class="text-text-light max-w-[500px] mx-auto mb-8">{t.aboutPage.joinUs.subtitle}</p>
      <a href={`${import.meta.env.BASE_URL}careers`} class="inline-flex items-center gap-2.5 bg-primary text-white font-semibold px-8 py-4 rounded-full hover:bg-accent hover:text-primary transition-[background-color,color,transform] hover:-translate-y-0.5">
        {t.aboutPage.joinUs.cta}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  <DualCta locale="ms" />
  <Contact locale="ms" />
  <Footer locale="ms" />
  <FloatingButtons locale="ms" />
</Layout>
