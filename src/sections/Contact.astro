---
import { client } from '../lib/sanity'
import { officesQuery } from '../lib/sanity.queries'

let offices = [
  { name: 'Kuala Lumpur', addr: 'Menara HLX, Suite 12-01' },
  { name: 'Penang', addr: '25 Beach Street, Suite 8' },
  { name: 'Johor Bahru', addr: 'Menara JLand, Level 15' },
]
let whatsapp = '+60123456790'
let email = 'hello@doublebraincreative.com'
let phone = '+60 3-1234 5678'

try {
  const docs = await client.fetch(officesQuery)
  if (docs?.length > 0) {
    offices = docs.map((d: any) => ({ name: d.name, addr: d.address?.replace(/\n/g, ', ') || 'Main Office' }))
  }
} catch {}
---

<section id="contact" class="py-[120px] max-sm:py-20 bg-bg-alt">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
    <div class="text-center mb-16 reveal">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="w-10 h-px bg-accent" />
        <span class="text-xs font-semibold tracking-[0.2em] uppercase text-accent">Get In Touch</span>
        <span class="w-10 h-px bg-accent" />
      </div>
      <h2 class="font-heading text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.05] tracking-[-0.03em] text-primary mb-4">Let's Talk About Your Event</h2>
      <p class="text-text-light text-[1.05rem] max-w-[500px] mx-auto leading-relaxed reveal reveal-delay-1">
        Have an event in mind? A wild idea? Tell us about it and we'll bring it to life.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 max-w-[1000px] mx-auto">
      <div class="space-y-4 reveal">
        <a href={`https://wa.me/${whatsapp}`} target="_blank" rel="noopener"
          class="flex items-center gap-4 p-5 rounded-xl bg-surface border border-white/10 hover:bg-[#25D366] hover:text-white hover:border-[#25D366] transition-all duration-500 hover:translate-x-1 group">
          <div class="w-12 h-12 rounded-xl bg-[#25D366]/10 flex items-center justify-center group-hover:bg-white/20 transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <div class="text-xs text-text-light group-hover:text-white/70 transition-colors">WhatsApp</div>
            <div class="font-semibold text-primary">{whatsapp}</div>
          </div>
        </a>

        <a href={`mailto:${email}`}
          class="flex items-center gap-4 p-5 rounded-xl bg-surface border border-white/10 hover:bg-accent hover:text-white hover:border-accent transition-all duration-500 hover:translate-x-1 group">
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center group-hover:bg-white/20 transition-colors">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </div>
          <div>
            <div class="text-xs text-text-light group-hover:text-white/70 transition-colors">Email</div>
            <div class="font-semibold text-primary">{email}</div>
          </div>
        </a>

        <a href={`tel:${phone.replace(/[^+\d]/g, '')}`}
          class="flex items-center gap-4 p-5 rounded-xl bg-surface border border-white/10 hover:bg-primary hover:text-primary hover:border-primary transition-all duration-500 hover:translate-x-1 group">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-white/20 transition-colors">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          </div>
          <div>
            <div class="text-xs text-text-light group-hover:text-white/70 transition-colors">Phone</div>
            <div class="font-semibold text-primary">{phone}</div>
          </div>
        </a>
      </div>

      <div class="reveal reveal-delay-1">
        <form action="https://formspree.io/f/{import.meta.env.FORMSPREE_FORM_ID || 'YOUR_FORM_ID'}" method="POST" class="bg-surface p-8 rounded-2xl border border-white/10">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="name" class="text-sm font-semibold text-primary block mb-1.5">Full Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl bg-bg-alt border border-white/10 text-primary text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-[border-color,box-shadow]" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="text-sm font-semibold text-primary block mb-1.5">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-bg-alt border border-white/10 text-primary text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-[border-color,box-shadow]" placeholder="your@email.com" />
            </div>
          </div>
          <div class="mb-5">
            <label for="phone" class="text-sm font-semibold text-primary block mb-1.5">Phone</label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl bg-bg-alt border border-white/10 text-primary text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-[border-color,box-shadow]" placeholder="+60 1X-XXX XXXX" />
          </div>
          <div class="mb-5">
            <label for="message" class="text-sm font-semibold text-primary block mb-1.5">Tell Us About Your Event</label>
            <textarea id="message" name="message" rows={5} required class="w-full px-4 py-3 rounded-xl bg-bg-alt border border-white/10 text-primary text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-[border-color,box-shadow] resize-none" placeholder="What kind of event? How many guests? What's your vision?"></textarea>
          </div>
          <button type="submit" class="w-full bg-accent text-primary font-semibold px-8 py-4 rounded-xl hover:bg-accent-dark transition-[background-color,transform] hover:-translate-y-0.5 shadow-lg shadow-accent/30">
            Send Message
          </button>
        </form>
      </div>
    </div>

    <div class="text-center mt-12 reveal">
      <a href="/location" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-accent transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        Visit Our Office — View Map & Directions
      </a>
    </div>
  </div>
</section>
