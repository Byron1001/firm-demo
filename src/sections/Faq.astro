---
import { client } from '../lib/sanity'
import { faqsQuery } from '../lib/sanity.queries'

let faqs = [
  { question: 'What types of events do you handle?', answer: 'We specialize in corporate events & conferences, weddings, branding & creative design, exhibitions & trade shows, product launches, and private & social events.' },
  { question: 'How do I start planning my event?', answer: 'Reach out via WhatsApp, phone, or our contact form. We will schedule a free chat to understand your vision, budget, and requirements with no obligation.' },
  { question: 'Do you handle events outside of Kuala Lumpur?', answer: 'Absolutely. With three locations in Kuala Lumpur, Penang, and Johor Bahru, we manage events across Malaysia and can coordinate destination events upon request.' },
  { question: 'What is your pricing structure?', answer: 'We provide transparent, customized quotes based on your event scope, requirements, and budget. Pricing is discussed during your first meeting with us.' },
]

try {
  const docs = await client.fetch(faqsQuery)
  if (docs?.length > 0) {
    faqs = docs.map((d: any) => ({ question: d.question, answer: d.answer }))
  }
} catch {}
---

<section class="py-[120px] max-sm:py-20 bg-surface" id="faq">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="w-10 h-px bg-accent bar-reveal" />
        <span class="text-xs font-semibold tracking-[0.15em] uppercase text-accent">FAQ</span>
        <span class="w-10 h-px bg-accent bar-reveal" />
      </div>
      <h2 class="font-heading text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.15] tracking-[-0.02em] text-primary mb-4">Frequently Asked Questions</h2>
      <p class="text-text-light text-[1.05rem] max-w-[500px] mx-auto leading-relaxed">
        Answers to common questions about our event services and planning process.
      </p>
    </div>
    <div class="max-w-[720px] mx-auto space-y-4">
      {faqs.map((faq, i) => (
        <details class="group bg-bg-alt border border-white/10 rounded-2xl overflow-hidden transition-[box-shadow] duration-300 hover:shadow-md [&[open]]:shadow-md">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none">
            <span class="font-heading font-semibold text-sm text-primary pr-4">{faq.question}</span>
            <svg class="w-4 h-4 min-w-4 text-accent transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
          </summary>
          <div class="px-6 pb-5 pt-0 border-t border-white/10">
            <p class="text-text-light text-sm leading-relaxed">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
