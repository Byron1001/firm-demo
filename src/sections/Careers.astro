---
import { client } from '../lib/sanity'
import { careersQuery } from '../lib/sanity.queries'
import { ICONS } from '../icons'

let jobs = [
  { title: 'Event Coordinator', dept: 'Corporate Events', location: 'Kuala Lumpur', type: 'Full-Time', desc: 'Plan and execute corporate events, conferences, and product launches. 2+ years of event coordination experience with strong organisational and communication skills required.', linkedin: 'https://www.linkedin.com/jobs/search/?keywords=Event%20Coordinator%20Double%20Brain%20Creative' },
  { title: 'Wedding Planner', dept: 'Weddings & Social Events', location: 'Penang', type: 'Full-Time', desc: 'Lead wedding planning and day-of coordination for our Penang clients. 3+ years of wedding planning experience, a keen eye for detail, and a passion for creating magical moments.', linkedin: 'https://www.linkedin.com/jobs/search/?keywords=Wedding%20Planner%20Double%20Brain%20Creative' },
  { title: 'Creative Designer', dept: 'Branding & Design', location: 'Kuala Lumpur', type: 'Full-Time', desc: 'Design event branding, stage visuals, and marketing materials. Proficiency in Adobe Creative Suite, strong portfolio, and 2+ years of design experience required.', linkedin: 'https://www.linkedin.com/jobs/search/?keywords=Creative%20Designer%20Double%20Brain%20Creative' },
  { title: 'Event Intern', dept: 'Operations', location: 'Johor Bahru', type: 'Internship', desc: 'Join our team for a 3-month internship. Assist with event setup, vendor coordination, and on-site support. Ideal for students pursuing hospitality or event management.', linkedin: 'https://www.linkedin.com/jobs/search/?keywords=Event%20Intern%20Double%20Brain%20Creative' },
]

try {
  const docs = await client.fetch(careersQuery)
  if (docs?.length > 0) {
    jobs = docs.map((d: any) => ({ title: d.title, dept: d.department, location: d.location, type: d.type, desc: d.description, linkedin: d.linkedinUrl || 'https://linkedin.com/jobs' }))
  }
} catch {}
---

<section id="careers" class="py-[120px] max-sm:py-20 bg-surface">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-10 h-px bg-accent" />
        <span class="text-xs font-semibold tracking-[0.15em] uppercase text-accent">Join Our Team</span>
      </div>
      <h2 class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.15] tracking-[-0.02em] text-primary mb-4">Careers</h2>
      <p class="text-text-light text-[1.1rem] max-w-[600px] leading-relaxed mb-16">
        Join a passionate team that brings extraordinary events to life across Malaysia.
      </p>

    <div class="space-y-4">
      {jobs.map((job) => (
          <div class="group bg-bg-alt border border-white/10 rounded-2xl p-6 md:p-8 transition-[box-shadow,border-color,transform] duration-500 hover:shadow-lg hover:border-accent/30 hover:-translate-y-0.5">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-1.5">
                  <h3 class="font-heading text-xl font-bold text-primary">{job.title}</h3>
                  <span class="text-[11px] font-semibold uppercase tracking-wider px-3 py-1 rounded-full bg-accent/10 text-accent">{job.type}</span>
                </div>
                <p class="text-sm text-text-light">{job.dept}</p>
              </div>
              <a
                href={job.linkedin}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#0A66C2] text-white text-sm font-semibold rounded-xl hover:bg-[#004182] transition-[background-color,transform] hover:-translate-y-0.5 self-start"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                Apply on LinkedIn
              </a>
            </div>
            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-text-light mb-4">
              <span class="flex items-center gap-1.5">
                <span class="w-3.5 h-3.5" set:html={ICONS.briefcase} />
                {job.dept}
              </span>
              <span class="flex items-center gap-1.5">
                <span class="w-3.5 h-3.5" set:html={ICONS.mapPin} />
                {job.location}
              </span>
              <span class="flex items-center gap-1.5">
                <span class="w-3.5 h-3.5" set:html={ICONS.clock} />
                {job.type}
              </span>
            </div>
            <p class="text-text-light text-[0.95rem] leading-relaxed">{job.desc}</p>
          </div>
      ))}
    </div>

      <div class="mt-10 p-8 md:p-10 rounded-2xl bg-surface border border-white/10 text-center">
        <h3 class="font-heading text-xl font-bold text-primary mb-3">Don't See the Right Role?</h3>
        <p class="text-text-light text-[0.95rem] leading-relaxed max-w-[500px] mx-auto mb-6">
          We are always looking for talented individuals. Send your resume and we will keep you in mind for future opportunities.
        </p>
        <a
          href="mailto:careers@doublebraincreative.com?subject=General%20Application%20-%20%5BYour%20Name%5D"
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-primary text-sm font-semibold rounded-xl hover:bg-accent-dark transition-[background-color,transform] hover:-translate-y-0.5"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Send Resume
        </a>
      </div>
  </div>
</section>
