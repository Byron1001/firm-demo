---
import { useTranslations } from '../i18n'

interface Props { locale?: 'en' | 'ms'; }
const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);

const items = t.marquee
---

<section class="py-16 bg-bg-dark border-t border-b border-white/5">
  <div class="max-w-[1000px] mx-auto px-6 lg:px-16">
    <div class="flex flex-wrap justify-center gap-3 stagger-reveal">
      {items.map((item, i) => (
        <span key={i} class="px-5 py-2.5 rounded-full bg-white/5 border border-white/10 text-sm font-semibold text-white/70 hover:text-accent hover:border-accent/30 transition-colors duration-300">
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
