---
import { asset } from '../lib/assets'

const logos = [
  { name: 'Petronas', img: asset('/images/clients/petronas.svg') },
  { name: 'AirAsia', img: asset('/images/clients/airasia.svg') },
  { name: 'Grab', img: asset('/images/clients/grab.svg') },
  { name: 'Shopee', img: asset('/images/clients/shopee.svg') },
  { name: 'CelcomDigi', img: asset('/images/clients/celcomdigi.png') },
  { name: 'Nestlé', img: asset('/images/clients/nestle.svg') },
  { name: 'Sunway', img: asset('/images/clients/sunway.svg') },
  { name: 'IHH', img: asset('/images/clients/ihh.svg') },
  { name: 'Maybank', img: asset('/images/clients/maybank.svg') },
  { name: 'CIMB', img: asset('/images/clients/cimb.svg') },
  { name: 'Gamuda', img: asset('/images/clients/gamuda.svg') },
  { name: 'RHB', img: asset('/images/clients/rhb.png') },
]
---

<section class="py-[120px] max-sm:py-20 bg-bg-alt overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 mb-12 reveal">
    <div class="flex items-center gap-3 mb-4 justify-center">
      <span class="w-10 h-px bg-accent bar-reveal" />
      <span class="text-xs font-semibold tracking-[0.2em] uppercase text-accent">Trusted By</span>
      <span class="w-10 h-px bg-accent bar-reveal" />
    </div>
    <p class="text-center text-text-light/60 text-sm max-w-[400px] mx-auto">
      We are proud to have worked with
    </p>
  </div>

  <div class="overflow-hidden reveal mb-12">
    <div class="flex gap-20 animate-marquee w-max items-center px-8">
      {[...logos, ...logos].map((l, i) => (
        <div key={i} class="flex items-center flex-shrink-0">
          <img src={l.img} alt={l.name} class="h-10 w-auto object-contain max-w-[160px]" loading="lazy" />
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 reveal reveal-delay-1">
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
      {logos.map((l) => (
        <div class="h-16 rounded-xl bg-surface border border-white/10 flex items-center justify-center px-4 transition-[border-color,transform,box-shadow] duration-300 hover:border-accent/30 hover:-translate-y-0.5 hover:shadow-md">
          <img src={l.img} alt={l.name} class="h-10 w-auto max-w-[100px] object-contain" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>
