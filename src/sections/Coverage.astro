---
import { client } from '../lib/sanity'
import { officesQuery } from '../lib/sanity.queries'

let cities = ['Kuala Lumpur', 'Penang', 'Johor Bahru', 'Selangor', 'Melaka', 'Ipoh', 'Kota Kinabalu', 'Kuching']
let offices = [
  { name: 'Kuala Lumpur', address: 'Suite 12-01, Menara HLX<br />Kuala Lumpur, 50050' },
  { name: 'Penang', address: '25 Beach Street, Suite 8<br />George Town, Penang 10300' },
  { name: 'Johor Bahru', address: 'Level 15, Menara JLand<br />Johor Bahru, 80000' },
]

try {
  const docs = await client.fetch(officesQuery)
  if (docs?.length > 0) {
    offices = docs.map((d: any) => ({ name: d.name, address: d.address?.replace(/\n/g, '<br />') }))
  }
} catch (e) { console.error('Sanity fetch failed (coverage):', e) }
---

<section class="py-[120px] max-sm:py-20 bg-bg-dark text-white overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 mb-16">
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="w-10 h-px bg-accent bar-reveal" />
      <span class="text-xs font-semibold tracking-[0.2em] uppercase text-accent">Where We Are</span>
    </div>
    <h2 class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.05] tracking-[-0.03em] max-w-[600px] reveal reveal-delay-1">
      We've Produced Events Across Malaysia
    </h2>
  </div>

  <div class="overflow-hidden mb-16" data-parallax="0.15">
    <div class="flex gap-8 animate-marquee w-max">
      {[...cities, ...cities].map((c, i) => (
        <span key={i} class="font-heading text-[clamp(3rem,6vw,5rem)] font-bold text-white/5 whitespace-nowrap tracking-[-0.03em]">{c}</span>
      ))}
    </div>
  </div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {offices.map((o) => (
        <div class="p-8 rounded-2xl bg-white/5 border border-white/10 reveal">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-white mb-1">{o.name}</h3>
          <p class="text-white/45 text-sm" set:html={o.address} />
        </div>
      ))}
    </div>
  </div>
</section>
