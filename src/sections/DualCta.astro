---
import { asset } from '../lib/assets'
import { useTranslations } from '../i18n'

interface Props { locale?: 'en' | 'ms'; }
const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);
---

<section class="py-[120px] max-sm:py-20 bg-bg-dark text-white overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 mb-12 text-center">
    <p class="text-accent text-xs font-semibold tracking-[0.2em] uppercase mb-4 reveal">{t.dualCta.sectionLabel}</p>
    <h2 class="font-heading text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.05] tracking-[-0.03em] reveal">
      {t.dualCta.heading}
    </h2>
  </div>

  <div class="max-w-[1000px] mx-auto px-6 lg:px-16 grid grid-cols-1 md:grid-cols-2 gap-6 reveal reveal-delay-2">
    <a href={`${import.meta.env.BASE_URL}#contact`} class="group relative aspect-[4/3] rounded-2xl overflow-hidden shadow-[0_0_30px_-15px_#F38A14] hover:shadow-[0_0_40px_-10px_#F38A14] transition-shadow duration-500">
      <img src={asset('/images/sections/dualcta-01.jpg')} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
      <div class="absolute bottom-0 left-0 right-0 p-8">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase text-accent mb-1">{t.dualCta.cards[0].label}</p>
        <h3 class="font-heading text-2xl font-bold text-white mb-2">{t.dualCta.cards[0].title}</h3>
        <span class="inline-flex items-center gap-2 text-sm font-semibold text-white/70 group-hover:text-accent transition-colors">
          {t.dualCta.cards[0].cta}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </span>
      </div>
    </a>
    <a href={`${import.meta.env.BASE_URL}#contact`} class="group relative aspect-[4/3] rounded-2xl overflow-hidden shadow-[0_0_30px_-15px_#F38A14] hover:shadow-[0_0_40px_-10px_#F38A14] transition-shadow duration-500">
      <img src={asset('/images/sections/dualcta-02.jpg')} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
      <div class="absolute bottom-0 left-0 right-0 p-8">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase text-accent mb-1">{t.dualCta.cards[1].label}</p>
        <h3 class="font-heading text-2xl font-bold text-white mb-2">{t.dualCta.cards[1].title}</h3>
        <span class="inline-flex items-center gap-2 text-sm font-semibold text-white/70 group-hover:text-accent transition-colors">
          {t.dualCta.cards[1].cta}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </span>
      </div>
    </a>
  </div>
</section>
