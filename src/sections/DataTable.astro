---
import { client } from '../lib/sanity'

let projects = [
  { participants: '2,000', industry: 'Sports', type: 'Live Event', location: 'Kuala Lumpur' },
  { participants: '5,000', industry: 'Pharmaceutical', type: 'Exhibition', location: 'Penang' },
  { participants: '1,200', industry: 'Tech', type: 'Corporate Summit', location: 'Kuala Lumpur' },
  { participants: '3,500', industry: 'Automotive', type: 'Product Launch', location: 'Selangor' },
  { participants: '850', industry: 'Finance', type: 'Gala Dinner', location: 'Kuala Lumpur' },
  { participants: '12,000', industry: 'Retail', type: 'Brand Activation', location: 'Johor Bahru' },
  { participants: '450', industry: 'Education', type: 'Conference', location: 'Penang' },
  { participants: '6,000', industry: 'Aviation', type: 'Live Event', location: 'Kuala Lumpur' },
]

try {
  const docs = await client.fetch(`*[_type == "project"] | order(order asc)`)
  if (docs?.length > 0) {
    projects = docs.map((d: any) => ({
      participants: d.participants || '—',
      industry: d.industry || '—',
      type: d.eventType || '—',
      location: d.location || '—',
    }))
  }
} catch (e) { console.error('Sanity fetch failed (projects):', e) }
---

<section class="py-[120px] max-sm:py-20 bg-surface border-b border-white/5 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 mb-12">
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="w-10 h-px bg-accent bar-reveal" />
      <span class="text-xs font-semibold tracking-[0.2em] uppercase text-accent">By the Numbers</span>
    </div>
    <p class="text-text-light text-sm max-w-[400px] reveal reveal-delay-1">From intimate gatherings to large-scale productions — a snapshot of the events we've delivered.</p>
  </div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 overflow-x-auto scrollbar-hide reveal">
    <table class="w-full text-left text-sm border-collapse min-w-[600px]">
      <thead>
        <tr class="border-b border-white/10">
          <th class="pb-3 pr-6 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">Participants</th>
          <th class="pb-3 pr-6 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">Industry</th>
          <th class="pb-3 pr-6 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">Event Type</th>
          <th class="pb-3 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">Location</th>
        </tr>
      </thead>
      <tbody>
        {projects.map((p) => (
          <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
            <td class="py-4 pr-6 font-heading text-lg font-bold text-primary">{p.participants}</td>
            <td class="py-4 pr-6">
              <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-xs font-medium text-text-light">{p.industry}</span>
            </td>
            <td class="py-4 pr-6 text-text-light">{p.type}</td>
            <td class="py-4 text-text-light">{p.location}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
