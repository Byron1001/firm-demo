---
import { client } from '../lib/sanity'
import { useTranslations } from '../i18n'

export interface Props { locale?: string }
const { locale = 'en' } = Astro.props
const t = useTranslations(locale)

const rawRows = t.dataTable.rows as string[][]
let projects = rawRows.map((r: string[]) => ({
  participants: r[0],
  industry: r[1],
  type: r[2],
  location: r[3],
}))

try {
  const docs = await client.fetch(`*[_type == "project"] | order(order asc)`)
  if (docs?.length > 0) {
    projects = docs.map((d: any) => ({
      participants: d.participants || '—',
      industry: d.industry || '—',
      type: d.eventType || '—',
      location: d.location || '—',
    }))
  }
} catch (e) { console.error('Sanity fetch failed (projects):', e) }
---

<section class="py-[120px] max-sm:py-20 bg-surface border-b border-white/5 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 mb-12">
    <p class="text-text-light text-sm max-w-[400px] reveal">{t.dataTable.description}</p>
  </div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 overflow-x-auto scrollbar-hide reveal reveal-delay-1">
    <table class="w-full text-left text-sm border-collapse min-w-[600px]">
      <thead>
        <tr class="border-b border-white/10">
          <th class="pb-3 pr-6 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">{t.dataTable.columns.participants}</th>
          <th class="pb-3 pr-6 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">{t.dataTable.columns.industry}</th>
          <th class="pb-3 pr-6 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">{t.dataTable.columns.eventType}</th>
          <th class="pb-3 font-heading text-xs font-semibold tracking-[0.1em] uppercase text-text-muted">{t.dataTable.columns.location}</th>
        </tr>
      </thead>
      <tbody>
        {projects.map((p) => (
          <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
            <td class="py-4 pr-6 font-heading text-lg font-bold text-primary">{p.participants}</td>
            <td class="py-4 pr-6">
              <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-xs font-medium text-text-light">{p.industry}</span>
            </td>
            <td class="py-4 pr-6 text-text-light">{p.type}</td>
            <td class="py-4 text-text-light">{p.location}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
