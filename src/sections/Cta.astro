---
---

<section class="relative py-32 overflow-hidden bg-bg-dark">
  <img
    src="/images/sections/pexels-cta-2k.jpg"
    alt=""
    class="absolute inset-0 w-full h-full object-cover will-change-transform"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-[#0f0f1a] via-[#0f0f1a]/70 to-transparent" />

  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 relative z-10">
    <div class="max-w-[600px]">
      <h2 class="font-heading text-[clamp(2rem,4vw,3.2rem)] font-bold leading-[1.05] tracking-[-0.03em] text-white mb-4">
        Let's Create Something Extraordinary Together
      </h2>
      <p class="text-white/60 max-w-[480px] mb-10 text-[1.05rem] leading-relaxed">
        Whether it's a corporate conference, a dream wedding, or a creative brand launch, our team is ready to bring your vision to life.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/#contact"
          class="inline-flex items-center gap-2.5 bg-accent text-primary font-semibold px-8 py-4 rounded-full hover:bg-accent-dark transition-[background-color,transform] hover:-translate-y-0.5">
          Start Your Event
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href="tel:+60312345678"
          class="inline-flex items-center gap-2.5 bg-transparent text-white font-semibold px-8 py-4 rounded-full border border-white/20 hover:border-accent hover:text-accent transition-[border-color,color,transform] hover:-translate-y-0.5">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          Call Now
        </a>
      </div>
    </div>
  </div>
</section>
