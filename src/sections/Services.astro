---
import { client } from '../lib/sanity'
import { practiceAreasQuery } from '../lib/sanity.queries'
import { asset } from '../lib/assets'
import { useTranslations } from '../i18n'

export interface Props { locale?: string }
const { locale = 'en' } = Astro.props
const t = useTranslations(locale)

let services = t.expertise.services.map((s: { num: string; title: string; desc: string }) => ({
  num: s.num,
  title: s.title,
  desc: s.desc,
  slug: s.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || s.num,
}))

const stickyColors = ['#C3F73A', '#95E06C', '#F38A14', '#68B684', '#C3F73A']
const stickySpins = ['-3deg', '4deg', '-5deg', '3deg', '-4deg']

try {
  const docs = await client.fetch(practiceAreasQuery)
  if (docs?.length > 0) {
    services = docs.map((d: any, i: number) => ({
      num: String(i + 1).padStart(2, '0'),
      title: d.title,
      desc: d.description || services[i]?.desc || '',
      slug: (d.title || '').toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') || services[i]?.slug || '',
    }))
  }
} catch (e) { console.error('Sanity fetch failed (services):', e) }
---

<section id="services" class="py-[120px] max-sm:py-20 bg-bg-alt">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 mb-16">
    <h2 class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.05] tracking-[-0.03em] reveal">
      {t.expertise.heading}
    </h2>
  </div>

  <div class="stack-spacer relative h-[450vh]">
    <div class="sticky top-[12vh] h-[76vh] flex items-center justify-center">
      <div class="relative w-[300px] sm:w-[380px] aspect-[3/4]">
        {services.map((s, i) => (
          <a
            href={`/services/${s.slug}`}
            class="stack-card absolute inset-0 rounded-2xl overflow-hidden group"
            style={`background-color: ${stickyColors[i % stickyColors.length]}; --spin: ${stickySpins[i % stickySpins.length]}; --z: ${10 + i}; transition-delay: ${i * 0.12}s;`}
          >
            <div class="absolute top-0 right-0 w-14 h-14 bg-gradient-to-bl from-black/10 to-transparent rounded-bl-2xl pointer-events-none" />
            <div class="p-8 flex flex-col h-full">
              <span class="text-surface/50 font-heading text-sm font-semibold tracking-[0.15em] mb-2 block">{s.num}</span>
              <h3 class="font-heading text-2xl font-bold text-surface mb-2">{s.title}</h3>
              <p class="text-surface/60 text-sm leading-relaxed flex-1">{s.desc}</p>
              <span class="inline-flex items-center gap-2 text-surface font-semibold text-sm mt-4 group-hover:gap-3 transition-all duration-300">
                {t.services.explore}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
