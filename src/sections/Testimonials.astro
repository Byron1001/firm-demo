---
import { client } from '../lib/sanity'
import { testimonialsQuery } from '../lib/sanity.queries'
import { useTranslations } from '../i18n'

export interface Props { locale?: string }
const { locale = 'en' } = Astro.props
const t = useTranslations(locale)

const ccolors = ['#F38A14', '#95E06C', '#C3F73A', '#68B684', '#F38A14', '#95E06C', '#C3F73A', '#68B684']
const caseSlugs = ['petronas-leadership-summit', 'sunway-wedding-fair', 'grab-brand-launch', 'celcomdigi-conference', 'airasia-annual-gala', 'shopeefest-malaysia', 'grab-brand-launch', 'petronas-leadership-summit']

let testimonials = t.testimonials.items.map((item: { text: string; name: string; role: string; company?: string }, i: number) => ({
  text: item.text,
  name: item.name,
  role: item.role,
  company: item.company || '',
  ccolor: ccolors[i % ccolors.length],
  caseSlug: caseSlugs[i % caseSlugs.length],
}))

try {
  const docs = await client.fetch(testimonialsQuery)
  if (docs?.length > 0) {
    testimonials = docs.map((d: any) => ({
      text: d.text, name: d.name, role: d.role || '',
      company: '', ccolor: '#6b7280', caseSlug: 'petronas-leadership-summit'
    }))
  }
  } catch (e) { console.error('Sanity fetch failed (testimonials):', e) }
---

<section id="testimonials" class="py-[120px] max-sm:py-20 bg-bg-dark text-white overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 mb-12">
    <h2 class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.05] tracking-[-0.03em] reveal">
      {t.testimonials.heading}
    </h2>
  </div>

  <div class="overflow-x-auto pb-6 scrollbar-hide snap-x snap-mandatory" data-testimonials>
    <div class="flex gap-6 px-6 lg:px-16 w-max stagger-reveal" data-testimonials-track>
      {testimonials.map((item, i) => (
        <div class="w-[420px] sm:w-[480px] bg-white/5 border border-white/10 p-10 rounded-2xl shrink-0 flex flex-col justify-between snap-start" data-testimonial-card>
          <div>
            <div class="text-accent text-6xl font-heading font-bold leading-none mb-4 opacity-20">&ldquo;</div>
            <p class="text-[0.95rem] leading-relaxed text-white/70">{item.text}</p>
          </div>
          <div class="pt-6 mt-6 border-t border-white/10">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center text-accent font-heading font-bold text-sm">
                  {item.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
                </div>
                <div>
                  <div class="font-semibold text-sm text-white">{item.name}</div>
                  <div class="text-xs text-white/40">{item.role}</div>
                </div>
              </div>
              {item.company && (
                <div class="h-8 px-4 rounded-lg bg-white/10 flex items-center">
                  <span class="text-xs font-bold tracking-[0.05em]" style={{ color: item.ccolor }}>{item.company}</span>
                </div>
              )}
            </div>
            {item.caseSlug && (
              <a href={`${import.meta.env.BASE_URL}case-study/${item.caseSlug}`} class="inline-flex items-center gap-1.5 mt-4 text-xs font-medium text-white/30 hover:text-accent transition-colors">
                {t.testimonials.seeCaseStudy}
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 flex items-center justify-between reveal">
    <div class="flex items-center gap-2 text-xs text-white/30" data-testimonials-counter>
      <span class="text-white/60 font-medium" data-testimonials-current>01</span>
      <span class="text-white/20">/</span>
      <span data-testimonials-total>{String(testimonials.length).padStart(2, '0')}</span>
    </div>
    <div class="flex gap-2">
      <button data-testimonials-prev class="w-11 h-11 rounded-full border border-white/20 flex items-center justify-center text-white/50 hover:border-accent hover:text-accent transition-colors cursor-pointer bg-transparent" aria-label={t.testimonials.prev}>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button data-testimonials-next class="w-11 h-11 rounded-full border border-white/20 flex items-center justify-center text-white/50 hover:border-accent hover:text-accent transition-colors cursor-pointer bg-transparent" aria-label={t.testimonials.next}>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.querySelector('[data-testimonials-track]')
    const current = document.querySelector('[data-testimonials-current]')
    const total = document.querySelector('[data-testimonials-total]')
    const prev = document.querySelector('[data-testimonials-prev]')
    const next = document.querySelector('[data-testimonials-next]')

    if (!track || !current || !prev || !next) return

    const getCardWidth = () => {
      const first = track.querySelector('[data-testimonial-card]')
      return first ? first.getBoundingClientRect().width + 24 : (480 + 24)
    }
    const updateCounter = () => {
      const scroll = track.scrollLeft
      const cw = getCardWidth()
      const idx = Math.round(scroll / cw)
      current.textContent = String(Math.min(idx + 1, parseInt(total?.textContent || '1', 10))).padStart(2, '0')
    }
    const scrollByCard = (dir: number) => {
      const cw = getCardWidth()
      track.scrollBy({ left: dir * cw, behavior: 'smooth' });
      (dir > 0 ? next : prev).disabled = true
      setTimeout(() => { updateCounter(); (dir > 0 ? next : prev).disabled = false }, 400)
    }

    track.addEventListener('scroll', updateCounter, { passive: true })
    prev.addEventListener('click', () => scrollByCard(-1))
    next.addEventListener('click', () => scrollByCard(1))
  })
</script>
