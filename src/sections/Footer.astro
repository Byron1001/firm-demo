---
const year = new Date().getFullYear()
---

<footer class="bg-bg-dark text-white/50 pt-20 pb-8">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 pb-12 border-b border-white/10">
      <div class="col-span-2 md:col-span-1">
        <span class="font-heading text-xl font-bold text-white">DB</span>
        <p class="mt-4 text-sm leading-relaxed max-w-[280px]">
          We craft experiences that audiences feel, not just attend. Malaysia's creative event partner since 2015.
        </p>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-[0.15em] uppercase text-white/60 mb-4">Explore</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/#portfolio" class="hover:text-accent transition-colors duration-300">Work</a></li>
          <li><a href="/#services" class="hover:text-accent transition-colors duration-300">Services</a></li>
          <li><a href="/#about" class="hover:text-accent transition-colors duration-300">About</a></li>
          <li><a href="/careers" class="hover:text-accent transition-colors duration-300">Careers</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-[0.15em] uppercase text-white/60 mb-4">Connect</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="https://www.instagram.com" target="_blank" rel="noopener" class="hover:text-accent transition-colors duration-300">Instagram</a></li>
          <li><a href="https://www.linkedin.com" target="_blank" rel="noopener" class="hover:text-accent transition-colors duration-300">LinkedIn</a></li>
          <li><a href="https://wa.me/60123456790" target="_blank" rel="noopener" class="hover:text-accent transition-colors duration-300">WhatsApp</a></li>
          <li><a href="mailto:hello@doublebraincreative.com" class="hover:text-accent transition-colors duration-300">Email</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-[0.15em] uppercase text-white/60 mb-4">Offices</h4>
        <ul class="space-y-2.5 text-sm">
          <li class="text-white/35">Kuala Lumpur</li>
          <li class="text-white/35">Penang</li>
          <li class="text-white/35">Johor Bahru</li>
        </ul>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 text-xs">
      <p>&copy; {year} Double Brain Creative &amp; Event Sdn Bhd.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-accent transition-colors">Privacy</a>
        <a href="#" class="hover:text-accent transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
