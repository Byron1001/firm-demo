---
import { useTranslations } from '../i18n'

export interface Props { locale?: string }
const { locale = 'en' } = Astro.props
const t = useTranslations(locale)
---


<button id="backToTop"
  class="fixed bottom-4 sm:bottom-6 left-4 sm:left-6 z-40 w-12 h-12 bg-accent rounded-full flex items-center justify-center text-white text-lg opacity-0 invisible transition-[transform,opacity,visibility] duration-500 hover:-translate-y-1 cursor-pointer border-none"
  aria-label={t.floatingButtons.backToTop}>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
</button>

<a href="tel:+60123456790"
  class="fixed bottom-24 sm:bottom-28 right-4 sm:right-6 z-40 w-14 h-14 bg-[#128C7E] rounded-full flex items-center justify-center text-white text-2xl shadow-lg shadow-[#128C7E]/40 hover:scale-110 transition-transform animate-float"
  aria-label={t.floatingButtons.callUs}>
  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
</a>

<script>
  import { scrollToTop } from '../utils/scrollAnimations';

  const btn = document.getElementById('backToTop');
  if (btn) {
    const onScroll = (e) => {
      const y = e ? e.detail.scroll : 0;
      const visible = y > 500;
      btn.classList.toggle('opacity-100', visible);
      btn.classList.toggle('visible', visible);
    };
    window.addEventListener('lenis-scroll', onScroll, { passive: true });
    btn.addEventListener('click', () => scrollToTop());
  }
</script>

<style>
  #backToTop.visible { opacity: 1 !important; visibility: visible !important; }
  #backToTop.opacity-100 { opacity: 1 !important; }
</style>
