---
import { client } from '../lib/sanity'
import { siteSettingsQuery } from '../lib/sanity.queries'
import { asset } from '../lib/assets'

let aboutTitle = 'Where passion meets precision'
let aboutP1 = 'Double Brain Creative & Event SDN BHD (202301030587(1524510-W)) is a Malaysian event management company that believes in the power of live experiences. We\'ve grown from a small creative studio into a trusted partner for some of the region\'s most recognised brands.'
let aboutP2 = 'We are a group of passionate event professionals who input creative and technical proficiency into bringing events to life. Whether corporate conferences, dream weddings, or immersive brand activations — we craft experiences that audiences feel, not just attend.'

try {
  const settings = await client.fetch(siteSettingsQuery)
  if (settings?.aboutDescription) {
    const blocks = settings.aboutDescription
    if (blocks.length > 0 && blocks[0].children?.[0]?.text) aboutTitle = blocks[0].children[0].text
    if (blocks.length > 1 && blocks[1].children?.[0]?.text) aboutP1 = blocks[1].children[0].text
    if (blocks.length > 2 && blocks[2].children?.[0]?.text) aboutP2 = blocks[2].children[0].text
  }
} catch (e) { console.error('Sanity fetch failed (about):', e) }
---

<section id="about" class="py-[120px] max-sm:py-20 bg-surface">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="relative reveal">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/5] clip-reveal">
          <img
            src={asset('/images/sections/about-team.jpg')}
            alt="Elegant event venue and decor setup"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div class="reveal reveal-delay-1">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-10 h-px bg-accent bar-reveal" />
          <span class="text-xs font-semibold tracking-[0.2em] uppercase text-accent">About Us</span>
        </div>
        <h2 class="font-heading text-[clamp(1.8rem,4vw,2.8rem)] font-bold leading-[1.05] tracking-[-0.03em] text-primary mb-6">{aboutTitle}</h2>
        <p class="text-text-light leading-relaxed mb-4">{aboutP1}</p>
        <p class="text-text-light leading-relaxed mb-8">{aboutP2}</p>

        <a href="/#contact" class="inline-flex items-center gap-2.5 bg-accent text-primary font-semibold px-6 py-3.5 rounded-full hover:bg-accent-dark transition-[background-color,transform] hover:-translate-y-0.5 text-sm">
          Get to know us
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>
