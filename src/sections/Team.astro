---
import { client } from '../lib/sanity'
import { teamMembersQuery } from '../lib/sanity.queries'
import { urlFor } from '../lib/sanity.image'
import { ICONS } from '../icons'

let team = [
  { name: 'Amira Yusof', role: 'Creative Director', spec: 'Vision & Concept Development', photo: '/images/sections/team-amira.jpg' },
  { name: 'Brandon Koh', role: 'Event Director', spec: 'Corporate Events & Conferences', photo: '/images/sections/team-brandon.jpg' },
  { name: 'Catherine Lim', role: 'Head of Weddings', spec: 'Wedding Planning & Coordination', photo: '/images/sections/team-catherine.jpg' },
  { name: 'Daniel Raj', role: 'Creative Lead', spec: 'Branding & Creative Design', photo: '/images/sections/team-daniel.jpg' },
  { name: 'Emily Chen', role: 'Senior Event Coordinator', spec: 'Exhibitions & Trade Shows', photo: '/images/sections/team-emily.jpg' },
  { name: 'Farid Ismail', role: 'Production Manager', spec: 'Technical Production & Logistics', photo: '/images/sections/team-farid.jpg' },
  { name: 'Grace Wong', role: 'Client Relations Director', spec: 'Client Experience & Partnerships', photo: '/images/sections/team-grace.jpg' },
  { name: 'Hannah Tan', role: 'Senior Designer', spec: 'Visual Design & Styling', photo: '/images/sections/team-hannah.jpg' },
]

try {
  const docs = await client.fetch(teamMembersQuery)
  if (docs?.length > 0) {
    team = docs.map((d: any) => ({
      name: d.name,
      role: d.role,
      spec: d.bio || '',
      photo: d.photo ? urlFor(d.photo).width(300).height(300).url() : '',
    }))
  }
} catch {}
---

<section id="team" class="py-[120px] max-sm:py-20 bg-surface">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-10 h-px bg-accent" />
        <span class="text-xs font-semibold tracking-[0.15em] uppercase text-accent">Our People</span>
      </div>
      <h2 class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.15] tracking-[-0.02em] text-primary mb-4">Meet Our Team</h2>
      <p class="text-text-light text-[1.1rem] max-w-[600px] leading-relaxed mb-10">
        Creative professionals dedicated to crafting unforgettable experiences with passion and precision.
      </p>
  </div>
  <div class="overflow-x-auto pb-4 scrollbar-hide">
    <div class="flex gap-6 px-6 lg:px-16 w-max stagger-reveal">
      {team.map((m, i) => (
          <div class="w-[280px] sm:w-[300px] bg-bg-alt border border-white/10 rounded-2xl overflow-hidden transition-[transform,box-shadow] duration-500 hover:-translate-y-1 hover:shadow-xl group snap-start shrink-0" data-tilt>
            <div class="aspect-square relative overflow-hidden">
              {m.photo ? (
                <img src={m.photo} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                  <span class="text-4xl font-bold text-gray-300">{m.name.split(' ').map(n => n[0]).join('')}</span>
                </div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-accent/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-lg font-bold mb-1">{m.name}</h3>
              <span class="text-accent text-sm font-semibold block mb-2">{m.role}</span>
              <p class="text-text-light text-sm leading-relaxed">{m.spec}</p>
              <div class="flex gap-3 mt-4 pt-4 border-t border-white/10">
                <a href={`https://linkedin.com/in/${m.name.toLowerCase().replace(/\s+/g, '-')}`} target="_blank" rel="noopener" class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-text-light hover:bg-accent hover:text-white transition-[background-color,color]" aria-label="LinkedIn"><span class="w-3.5 h-3.5" set:html={ICONS.linkedin} /></a>
                <a href={`https://x.com/${m.name.toLowerCase().replace(/\s+/g, '-')}`} target="_blank" rel="noopener" class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-text-light hover:bg-accent hover:text-white transition-[background-color,color]" aria-label="X"><span class="w-3.5 h-3.5" set:html={ICONS.x} /></a>
                <a href={`mailto:${m.name.toLowerCase().replace(/\s+/g, '.')}@doublebraincreative.com`} class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-text-light hover:bg-accent hover:text-white transition-[background-color,color]" aria-label="Email"><span class="w-3.5 h-3.5" set:html={ICONS.email} /></a>
              </div>
            </div>
          </div>
      ))}
    </div>
  </div>
</section>
