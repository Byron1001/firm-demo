---
import { client } from '../lib/sanity'
import { siteSettingsQuery } from '../lib/sanity.queries'
import { asset } from '../lib/assets'

let heroTitle = 'Step into\nthe Spotlight'
let heroDesc = 'We craft world-class spaces & events that create memories, initiate conversations and elevate ambitions.'

try {
  const settings = await client.fetch(siteSettingsQuery)
  if (settings?.heroTitle) heroTitle = settings.heroTitle
  if (settings?.heroDescription) heroDesc = settings.heroDescription
} catch {}
---

<section id="home" class="relative h-[100dvh] min-h-[700px] flex items-center overflow-hidden bg-bg-dark">
  <div class="absolute inset-0 overflow-hidden">
    <video
      autoplay muted playsinline preload="metadata"
      poster={asset('/images/sections/hero-bg.jpg')}
      class="w-full h-full object-cover will-change-transform"
      id="hero-video"
      data-observe-video
    >
      <source src={asset('/videos/showreel.mp4')} type="video/mp4" />
      <source src={asset('/videos/pexels/pexels-hero-conference-walk.mp4')} type="video/mp4" />
      <source src={asset('/videos/pexels/pexels-hero-diverse-group.mp4')} type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f0f1a] via-[#0f0f1a]/50 to-[#0f0f1a]/20" id="hero-overlay" />

    <button
      id="hero-mute-toggle"
      class="absolute bottom-6 right-6 z-20 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer border-none"
      aria-label="Toggle sound"
    >
      <svg id="icon-muted" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75L19.5 12m0 0l2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6l4.72-4.72a.75.75 0 011.28.531v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" /></svg>
      <svg id="icon-unmuted" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.531v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" /></svg>
    </button>

    <div class="absolute bottom-6 left-6 z-20 flex items-center gap-3">
      <span id="hero-indicator" class="flex gap-1.5">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse-dot" data-hero-dot="0" />
        <span class="w-2 h-2 rounded-full bg-white/30 transition-colors duration-500" data-hero-dot="1" />
        <span class="w-2 h-2 rounded-full bg-white/30 transition-colors duration-500" data-hero-dot="2" />
      </span>
      <span class="text-white/40 text-xs font-medium tracking-wider">Showreel</span>
    </div>
  </div>

  <div class="relative z-10 w-full" id="hero-content">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
      <div class="max-w-[900px]">
        <p class="text-accent font-heading text-sm font-semibold tracking-[0.2em] uppercase mb-6 animate-fade-in-up">
          Corporate Events · Weddings · Branding
        </p>
        <h1 class="font-heading text-[clamp(3rem,8vw,6rem)] font-bold leading-[0.9] tracking-[-0.04em] text-white mb-6 whitespace-pre-line animate-fade-in-up" style="animation-delay: 0.1s">
          {heroTitle}
        </h1>
        <p class="text-lg lg:text-xl text-white/50 leading-relaxed max-w-[520px] mb-10 animate-fade-in-up" style="animation-delay: 0.2s">
          {heroDesc}
        </p>
        <div class="flex flex-wrap gap-4 animate-fade-in-up" style="animation-delay: 0.3s">
          <a href="/#contact" class="inline-flex items-center gap-2.5 bg-accent text-primary font-semibold px-8 py-4 rounded-full hover:bg-accent-dark transition-[background-color,transform] hover:-translate-y-0.5">
            Start Your Event
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="https://wa.me/60123456790" target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 bg-white/10 text-white font-semibold px-8 py-4 rounded-full border border-white/20 hover:bg-[#25D366] hover:border-[#25D366] hover:text-white transition-all duration-300 hover:-translate-y-0.5">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('hero-video') as HTMLVideoElement
    const toggle = document.getElementById('hero-mute-toggle')
    const iconMuted = document.getElementById('icon-muted')
    const iconUnmuted = document.getElementById('icon-unmuted')
    const sources = video?.querySelectorAll('source') || []
    const dots = document.querySelectorAll('[data-hero-dot]')
    let currentSource = 0

    if (video && toggle && iconMuted && iconUnmuted) {
      toggle.addEventListener('click', () => {
        video.muted = !video.muted
        iconMuted.classList.toggle('hidden')
        iconUnmuted.classList.toggle('hidden')
      })
    }

    function switchToSource(index: number) {
      if (index === currentSource || !video) return
      currentSource = index
      const newSrc = sources[index]?.getAttribute('src') || ''
      if (newSrc) {
        const wasPlaying = !video.paused
        video.src = newSrc
        video.load()
        if (wasPlaying) video.play().catch(() => {})
      }
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.remove('bg-white/30')
          dot.classList.add('bg-accent', 'animate-pulse-dot')
        } else {
          dot.classList.remove('bg-accent', 'animate-pulse-dot')
          dot.classList.add('bg-white/30')
        }
      })
    }

    if (video && sources.length > 1) {
      video.addEventListener('ended', () => {
        const next = (currentSource + 1) % sources.length
        switchToSource(next)
      })
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => switchToSource(i))
    })
  })

  // --- Scroll-linked hero fade ---
  // state = f(scrollPosition): no animation running, just a direct mapping
  let ticking = false
  const hero = document.getElementById('home') as HTMLElement
  const heroContent = document.getElementById('hero-content') as HTMLElement
  const heroOverlay = document.getElementById('hero-overlay') as HTMLElement

  function updateHeroOnScroll() {
    if (!hero || !heroContent || !heroOverlay) return
    const rect = hero.getBoundingClientRect()
    const heroH = rect.height
    const viewH = window.innerHeight
    const scrollable = Math.max(viewH * 0.25, heroH - viewH)
    const progress = Math.max(0, Math.min(1, -rect.top / scrollable))

    heroContent.style.opacity = String(1 - progress)
    heroContent.style.transform = `translateY(${progress * 40}px) scale(${1 - progress * 0.04})`
    heroOverlay.style.opacity = String(0.6 + progress * 0.4)
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { updateHeroOnScroll(); ticking = false })
      ticking = true
    }
  }, { passive: true })
</script>
