---
import '../styles/global.css';
import { asset } from '../lib/assets';
import NotificationToast from '../components/NotificationToast';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Double Brain Creative & Event SDN BHD — Premier Event Management', description = 'We craft experiences that audiences feel, not just attend. Corporate events, weddings, branding, and exhibitions across Malaysia.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no">
    <link rel="icon" type="image/svg+xml" href={asset('/favicon.svg')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={asset('/images/sections/og-image.jpg')} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={asset('/images/sections/og-image.jpg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased">
    <div class="overflow-x-hidden">
      <slot />
    </div>
    <NotificationToast client:load />
  </body>
</html>

<script>
  import { initAll, destroyAll } from '../utils/scrollAnimations';

  document.addEventListener('DOMContentLoaded', () => {
    initAll();
  });

  if (import.meta.hot) {
    import.meta.hot.dispose(() => {
      destroyAll();
    });
  }
</script>
